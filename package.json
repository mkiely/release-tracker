{
  "name": "release-tracker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint:type": "node scripts/check-typography.mjs",
    "prebuild": "npm run lint:type",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "pretest": "npm run lint:type",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:contract": "openapi-typescript packages/sync-contract/openapi.yaml -o packages/sync-contract/src/generated.ts"
  },
  "dependencies": {
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.4.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
